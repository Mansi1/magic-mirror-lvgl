#include "lvgl/lvgl.h"
#include "lv_drv_conf.h"
#include "display/drm.h"
#include "ui.h"
#include <unistd.h>
#include <stdio.h>
#include <stdlib.h> // <--- THIS IS THE FIX FOR MALLOC

int main(void) {
    printf("Starting LVGL Mirror App...\n");
    lv_init();

    static lv_disp_drv_t disp_drv;
    lv_disp_drv_init(&disp_drv);

    printf("Initializing DRM hardware...\n");
    if (drm_disp_drv_init(&disp_drv) < 0) {
        printf("ERROR: DRM Init failed.\n");
        return -1;
    }

    // Allocate 1080p buffers on the Heap (Safe from Segfaults)
    printf("Allocating memory for 1080p buffers...\n");
    uint32_t buf_size = 1920 * 1080 / 10; 
    lv_color_t *buf1 = malloc(buf_size * sizeof(lv_color_t));
    lv_color_t *buf2 = malloc(buf_size * sizeof(lv_color_t));

    if (buf1 == NULL || buf2 == NULL) {
        printf("ERROR: Out of memory!\n");
        return -1;
    }

    static lv_disp_draw_buf_t draw_buf;
    lv_disp_draw_buf_init(&draw_buf, buf1, buf2, buf_size);

    disp_drv.draw_buf = &draw_buf;
    disp_drv.flush_cb = drm_flush;
    disp_drv.hor_res = 1920;
    disp_drv.ver_res = 1080;
    
    lv_disp_drv_register(&disp_drv);

    printf("Loading UI...\n");
    // If it still segfaults here, comment out ui_init() 
    // and use the label test from my previous message.
    ui_init(); 

    printf("Entering main loop. You should see the UI now!\n");
    while(1) {
        lv_timer_handler();
        usleep(5000);
    }
    return 0;
}
