#include "lvgl/lvgl.h"
#include "lv_drv_conf.h"
#include "display/drm.h"
#include "ui.h"
#include <unistd.h>
#include <stdio.h>
#include <stdlib.h>

int main(void) {
    printf("\n========================================\n");
    printf("   MAGIC MIRROR DIAGNOSTIC START\n");
    printf("========================================\n");

    lv_init();

    static lv_disp_drv_t disp_drv;
    lv_disp_drv_init(&disp_drv);

    printf("[LOG] Attempting DRM Init on /dev/dri/card0...\n");
    if (drm_disp_drv_init(&disp_drv) < 0) {
        printf("[ERROR] DRM Hardware handshake FAILED. Check cable/permissions.\n");
        return -1;
    }

    // Capture the hardware's real parameters
    uint32_t screen_w = disp_drv.hor_res;
    uint32_t screen_h = disp_drv.ver_res;
    
    printf("[INFO] Hardware Resolution: %u x %u\n", screen_w, screen_h);
    
    // Calculate the 'Stride' - this is usually the cause of the 3 columns
    // In 32-bit (4 bytes per pixel), 1920 should be 7680 bytes.
    uint32_t expected_pitch = screen_w * 4;
    printf("[INFO] Expected Pitch (32-bit): %u bytes per line\n", expected_pitch);

    // Buffer Allocation Logs
    uint32_t buf_rows = screen_h / 10;
    uint32_t buf_size = screen_w * buf_rows;
    printf("[LOG] Allocating %u pixels for Draw Buffer (Rows: %u)...\n", buf_size, buf_rows);

    lv_color_t *buf1 = malloc(buf_size * sizeof(lv_color_t));
    if (buf1 == NULL) {
        printf("[CRITICAL] Failed to allocate memory for buf1!\n");
        return -1;
    }
    printf("[LOG] Buffer 1 Memory Address: %p\n", (void*)buf1);

    static lv_disp_draw_buf_t draw_buf;
    lv_disp_draw_buf_init(&draw_buf, buf1, NULL, buf_size);

    disp_drv.draw_buf = &draw_buf;
    disp_drv.flush_cb = drm_flush;
    disp_drv.hor_res = screen_w;
    disp_drv.ver_res = screen_h;
    
    lv_disp_drv_register(&disp_drv);
    printf("[LOG] LVGL Driver Registered. Initializing UI...\n");

    ui_init(); 

    // Visual Calibration Markers
    // Top-Left (Red)
    lv_obj_t * tl = lv_obj_create(lv_scr_act());
    lv_obj_set_size(tl, 100, 100);
    lv_obj_set_style_bg_color(tl, lv_palette_main(LV_PALETTE_RED), 0);
    lv_obj_align(tl, LV_ALIGN_TOP_LEFT, 0, 0);

    // Bottom-Right (Blue)
    lv_obj_t * br = lv_obj_create(lv_scr_act());
    lv_obj_set_size(br, 100, 100);
    lv_obj_set_style_bg_color(br, lv_palette_main(LV_PALETTE_BLUE), 0);
    lv_obj_align(br, LV_ALIGN_BOTTOM_RIGHT, 0, 0);

    // Center Crosshair
    lv_obj_t * v_line = lv_obj_create(lv_scr_act());
    lv_obj_set_size(v_line, 4, screen_h);
    lv_obj_set_style_bg_color(v_line, lv_color_white(), 0);
    lv_obj_center(v_line);

    printf("[STATUS] Loop Active. Monitor the logs below for flush events.\n");
    printf("========================================\n\n");

    while(1) {
        lv_timer_handler();
        usleep(5000);
    }

    free(buf1);
    return 0;
}
